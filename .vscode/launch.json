{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug Uvicorn backend",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Node: Vite frontend dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--host"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Frontend + Backend",
      "configurations": [
        "Python: Debug Uvicorn backend",
        "Node: Vite frontend dev"
      ]
    }
  ]
}
